{
  "plugins": ["react", "import"],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/instrument/**",
              "components/layout/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Martian Mono|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Martian Mono, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|accent|ok|warn|err)$/]",
        "message": "<Badge> tone must be one of 'default' | 'accent' | 'ok' | 'warn' | 'err'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|block|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, block, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|accent|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'default' | 'accent' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Fader'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|defaultValue|min|max|step|onChange|className|key|ref|className|style|children)$/]",
        "message": "<Fader> doesn't accept that prop. Declared props: label, value, defaultValue, min, max, step, onChange, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|active|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: size, active, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Knob'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|defaultValue|min|max|step|size|unit|format|onChange|className|key|ref|className|style|children)$/]",
        "message": "<Knob> doesn't accept that prop. Declared props: label, value, defaultValue, min, max, step, size, unit, format, onChange, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Knob'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Knob> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LED'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|on|size|key|ref|className|style|children)$/]",
        "message": "<LED> doesn't accept that prop. Declared props: tone, on, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|orient|key|ref|className|style|children)$/]",
        "message": "<Meter> doesn't accept that prop. Declared props: value, orient."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meter'] > JSXAttribute[name.name='orient'] > Literal[value!=/^(?:h|v)$/]",
        "message": "<Meter> orient must be one of 'h' | 'v'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|actions|tone|children|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, actions, tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:raised|well)$/]",
        "message": "<Panel> tone must be one of 'raised' | 'well'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|label|disabled|className|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, label, disabled, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:onRemove|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: onRemove, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Transport'] > JSXAttribute > JSXIdentifier[name!=/^(?:playing|onPlayToggle|onStop|onPrev|onNext|showSkip|children|key|ref|className|style|children)$/]",
        "message": "<Transport> doesn't accept that prop. Declared props: playing, onPlayToggle, onStop, onPrev, onNext, showSkip, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Visualizer'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|running|bars|height|analyser|key|ref|className|style|children)$/]",
        "message": "<Visualizer> doesn't accept that prop. Declared props: mode, running, bars, height, analyser."
      },
      {
        "selector": "JSXOpeningElement[name.name='Visualizer'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:bars|wave)$/]",
        "message": "<Visualizer> mode must be one of 'bars' | 'wave'."
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/index.js"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
