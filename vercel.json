{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Bluesky Cardyb|Twitterbot|facebookexternalhit|Slackbot|Discordbot|TelegramBot|WhatsApp|LinkedInBot).*"
        }
      ],
      "destination": "/api/share"
    }
  ]
}
