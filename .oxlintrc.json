{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off"
  },
  "rules": {
    "react/jsx-no-undef": "off",
    "react/react-in-jsx-scope": "off",
    "no-underscore-dangle": ["error", { "allow": ["__APP_VERSION__"] }]
  },
  "env": {
    "browser": true
  },
  "ignorePatterns": ["dist", "node_modules", "hmla-design-system"]
}
